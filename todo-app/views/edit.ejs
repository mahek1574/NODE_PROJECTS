<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Task</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <a href="/" class="back-link">← Back to Dashboard</a>

        <div class="form-card">
            <h1 class="form-title">Edit Task</h1>
            
            <form action="/edit/<%= todo.id %>" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label class="form-label">Task Title</label>
                    <input type="text" name="title" value="<%= todo.title %>" class="form-control" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-control">
                        <option <%= todo.category === "Office" ? "selected" : "" %>>Office</option>
                        <option <%= todo.category === "Home" ? "selected" : "" %>>Home</option>
                        <option <%= todo.category === "Urgent" ? "selected" : "" %>>Urgent</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Current Image</label>
                    <% if (todo.image) { %>
                        <div style="margin-bottom: 1rem;">
                            <img src="/uploads/<%= todo.image %>" class="todo-image" style="width: 100px; height: 100px;">
                        </div>
                    <% } else { %>
                        <p style="color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1rem;">No image uploaded</p>
                    <% } %>
                    
                    <label class="form-label">Change Image (Optional)</label>
                    <input type="file" name="image" class="form-control">
                </div>

                <div style="margin-top: 2rem;">
                    <button type="submit" class="btn btn-primary" style="width: 100%;">Update Task</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>