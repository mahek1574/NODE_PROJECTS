<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Todo App</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Todo List</h1>
            <a href="/add" class="btn btn-primary">+ New Task</a>
        </header>

        <div class="todo-list">
            <% todos.forEach(todo => { %>
                <div class="todo-card">
                    <% if (todo.image) { %>
                        <img src="/uploads/<%= todo.image %>" class="todo-image" alt="Task image">
                    <% } else { %>
                        <div class="todo-image" style="display: flex; align-items: center; justify-content: center; background: #f1f5f9; color: #94a3b8; font-size: 1.5rem;">📋</div>
                    <% } %>

                    <div class="todo-content">
                        <h3 class="todo-title"><%= todo.title %></h3>
                        <div class="todo-meta">
                            <span class="badge badge-<%= todo.category.toLowerCase() %>"><%= todo.category %></span>
                            <span>• Task ID: #<%= todo.id.slice(-4) %></span>
                        </div>
                    </div>

                    <div class="todo-actions">
                        <a href="/edit/<%= todo.id %>" class="btn btn-outline" title="Edit">Edit</a>
                        <a href="/delete/<%= todo.id %>" class="btn btn-danger" title="Delete" onclick="return confirm('Are you sure?')">Delete</a>
                    </div>
                </div>
            <% }) %>

            <% if (todos.length === 0) { %>
                <div class="empty-state">
                    <div style="font-size: 3rem; margin-bottom: 1rem;">✨</div>
                    <p>No tasks available. Start by adding a new one!</p>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>