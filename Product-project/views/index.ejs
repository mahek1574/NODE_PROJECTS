<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Dashboard</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1>Product Dashboard</h1>
      <a class="btn btn-primary" href="/add">Add Product</a>
    </header>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <p>No products available. Click the button above to add one.</p>
      </div>
    <% } else { %>
      <div class="product-grid">
        <% products.forEach(p => { %>
          <div class="card">
            <div class="card-header">
              <h2 class="card-title"><%= p.name %></h2>
              <span class="badge"><%= p.category %></span>
            </div>
            <div class="card-body">
              <p><%= p.description %></p>
              <div class="price">₹<%= p.price %></div>
              <p style="margin-top: 0.5rem; font-size: 0.75rem;">Stock: <%= p.stock %></p>
            </div>
            <div class="card-footer">
              <a href="/edit/<%= p.id %>" class="btn btn-outline" style="flex: 1;">Edit</a>
              <a href="/delete/<%= p.id %>" class="btn btn-outline" style="flex: 1; color: var(--danger); border-color: #fee2e2;">Delete</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>